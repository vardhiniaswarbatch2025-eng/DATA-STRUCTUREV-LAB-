#include <stdio.h>

void insertionSort(int a[], int n) {
    //write your code here...
    int i,j,t;
	for(i=1;i<n;i++)
		{
			t =a[i];
		for(j=i-1;j>=0 && a[j]>t;j--)
			a[j+1]=a[j];
		a[j+1]=t;
		}
    
}

int main() {
    int a[20], n, i;

    scanf("%d", &n);

    for (i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    insertionSort(a, n);

    for (i = 0; i < n; i++) {
        printf("%d ", a[i]);
    }

    return 0;
}
